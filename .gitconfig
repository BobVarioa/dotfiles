[credential "https://github.com"]
	helper = 
	helper = !/usr/bin/gh auth git-credential
[credential "https://gist.github.com"]
	helper = 
	helper = !/usr/bin/gh auth git-credential
[core]
	autocrlf = input
[http]
	version = HTTP/2
[init]
	defaultBranch = main
[user]
	name = Bob Varioa
	email = bob.varioa@gmail.com
[push]
	autoSetupRemote = true
[credential]
	helper = cache --timeout 21600
	helper = oauth
