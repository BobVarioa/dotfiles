[diff]
    tool = kitty
    guitool = kitty.gui
[difftool]
    prompt = false
    trustExitCode = true
[difftool "kitty"]
    cmd = kitten diff $LOCAL $REMOTE
[difftool "kitty.gui"]
    cmd = kitten diff $LOCAL $REMOTE
[credential "https://github.com"]
	helper = 
	helper = !/usr/bin/gh auth git-credential
[credential "https://gist.github.com"]
	helper = 
	helper = !/usr/bin/gh auth git-credential
[core]
	autocrlf = input
[http]
	version = HTTP/2
[init]
	defaultBranch = main
[user]
	name = Bob Varioa
	email = bob.varioa@gmail.com
[push]
	autoSetupRemote = true
[credential]
	helper = cache --timeout 21600
	helper = oauth
